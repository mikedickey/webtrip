# WebTrip build base image
#
# A toolchain-only base image (no source baked in) used to:
#   - build WebTrip and run its tests in CI/CD
#   - serve as the base for AI agent development environments
#
# Source is expected to be mounted/cloned into /workspace at run time.
#
# Build from the repo root (the build context must be the repo root so the
# dependency pre-build can COPY Cargo.toml/Cargo.lock/package.json):
#   podman build -t ghcr.io/mikedickey/webtrip-build:latest -f containers/build/Containerfile .
#
# Bump a tool without editing the file:
#   podman build --build-arg RUST_NIGHTLY=nightly-2026-07-01 \
#       -f containers/build/Containerfile -t webtrip-build .
#
# NOTE: RUST_NIGHTLY must stay in sync with rust-toolchain.toml's channel,
# otherwise rustup will download a different nightly at build time and the
# baked-in toolchain pin is wasted.

FROM debian:bookworm-slim

ARG RUST_NIGHTLY=nightly-2026-06-13
ARG NODE_MAJOR=22
ARG WASM_PACK_VERSION=0.15.0
# NOTE: WASM_BINDGEN_VERSION must stay in sync with the wasm-bindgen version in
# Cargo.lock. wasm-pack only uses a local wasm-bindgen if its version matches
# the one the crate links against; a mismatch makes it fall back to downloading
# a prebuilt binary (which is linked against a newer glibc than bookworm ships).
ARG WASM_BINDGEN_VERSION=0.2.118
ARG CARGO_LLVM_COV_VERSION=0.8.7

LABEL org.opencontainers.image.title="webtrip-build" \
      org.opencontainers.image.description="Rust nightly + wasm-pack + Node toolchain for building WebTrip" \
      org.opencontainers.image.source="https://github.com/mikedickey/webtrip"

ENV DEBIAN_FRONTEND=noninteractive \
    RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH \
    # Fixed, out-of-/workspace target dir. The dependency pre-build (step 5)
    # populates it; runtime builds against mounted source reuse it. Do NOT
    # override CARGO_TARGET_DIR at runtime or the warm cache is bypassed.
    CARGO_TARGET_DIR=/opt/cargo-target \
    # Shared, writable cache dirs so any uid (CI as root, agents as non-root)
    # can use them. wasm-pack caches the wasm-bindgen CLI under XDG_CACHE_HOME
    # and npm caches under npm_config_cache; without writable caches a non-root
    # uid (whose HOME defaults to an unwritable "/") fails with permission
    # errors. Redirecting only the caches (rather than overriding HOME) keeps
    # HOME natural, avoiding rustup's "$HOME differs from euid" warning.
    XDG_CACHE_HOME=/opt/cache \
    npm_config_cache=/opt/cache/npm \
    # `npm run test:wasm` drives wasm-bindgen-test through a headless browser.
    # Point it at the apt-installed chromedriver (version-matched to chromium)
    # so it doesn't try to download a driver that mismatches the installed
    # browser. Headless-Chrome flags (--no-sandbox for running as root in a
    # container, --disable-dev-shm-usage for the small /dev/shm) come from the
    # webdriver.json at the repo root.
    CHROMEDRIVER=/usr/bin/chromedriver

# 1. OS packages: dev essentials + native build toolchain.
#    build-essential/pkg-config are needed because `npm run test` compiles
#    `cargo test` for the host (native), not WASM.
#    clang is needed for `npm run coverage:wasm`: the minicov crate (the WASM
#    coverage runtime) compiles C via the cc crate, and cc targets
#    wasm32-unknown-unknown with clang (gcc can't emit wasm). Without it the
#    build fails: `failed to find tool "clang"`.
#    chromium + chromium-driver provide the headless browser `npm run test:wasm`
#    drives via wasm-bindgen-test; installing them together keeps the driver and
#    browser versions in lockstep.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        build-essential \
        clang \
        pkg-config \
        ripgrep \
        jq \
        xz-utils \
        chromium \
        chromium-driver \
    && rm -rf /var/lib/apt/lists/*

# 2. Node.js (repo requires >=18; install current LTS).
RUN curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && node --version && npm --version

# 3. Rust nightly (pinned) via rustup, with the wasm target, rust-src, and
#    llvm-tools-preview. rust-src is required for the `-Zbuild-std` flag the
#    WASM build uses; llvm-tools-preview is required by cargo-llvm-cov.
#    `umask 000` so every file rustup writes under RUSTUP_HOME/CARGO_HOME is
#    world-writable from birth — see the note on step 7 for why we avoid a
#    trailing `chmod -R`.
RUN umask 000 \
    && curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs | \
        sh -s -- -y --no-modify-path --profile minimal \
            --default-toolchain "${RUST_NIGHTLY}" \
            --component rust-src \
            --component llvm-tools-preview \
            --target wasm32-unknown-unknown \
    && rustc --version && cargo --version

# 4. wasm-pack (pinned, prebuilt binary — avoids a from-source compile).
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64) target="x86_64-unknown-linux-musl" ;; \
        arm64) target="aarch64-unknown-linux-musl" ;; \
        *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    url="https://github.com/rustwasm/wasm-pack/releases/download/v${WASM_PACK_VERSION}/wasm-pack-v${WASM_PACK_VERSION}-${target}.tar.gz"; \
    curl -fsSL "$url" -o /tmp/wasm-pack.tar.gz; \
    tar -xzf /tmp/wasm-pack.tar.gz -C /tmp; \
    install -m 0755 "/tmp/wasm-pack-v${WASM_PACK_VERSION}-${target}/wasm-pack" /usr/local/bin/wasm-pack; \
    rm -rf /tmp/wasm-pack*; \
    wasm-pack --version

# 5. wasm-bindgen CLI, built from source so it links against this image's glibc.
#    wasm-pack would otherwise download a prebuilt wasm-bindgen/test-runner on
#    first use, and those are linked against a newer glibc than bookworm ships
#    (fails at runtime with "GLIBC_2.3x not found"). Installing a version-matched
#    CLI on PATH makes wasm-pack reuse it for both `build:wasm` and `test:wasm`
#    instead of downloading. Must match Cargo.lock — see WASM_BINDGEN_VERSION.
RUN umask 000 \
    && cargo install wasm-bindgen-cli --version "${WASM_BINDGEN_VERSION}" --locked \
    && wasm-bindgen --version \
    && wasm-bindgen-test-runner --version

# 6. cargo-llvm-cov, used by `npm run coverage` in CI.
RUN umask 000 \
    && cargo install cargo-llvm-cov --version "${CARGO_LLVM_COV_VERSION}" --locked \
    && cargo llvm-cov --version

# 7. Pre-build dependencies + std into CARGO_TARGET_DIR using a stub crate.
#    Only the manifests are copied, so this expensive layer is cached and only
#    re-runs when Cargo.toml/Cargo.lock change. We drive the build through the
#    project's own npm scripts so the rustflags/build-std flags are sourced from
#    package.json — guaranteeing the dependency + std fingerprints match what a
#    real build produces (otherwise the warm cache would silently miss).
#
#    Requires committed Cargo.lock + package.json (in the build context). At
#    runtime, real source is mounted at /workspace and only the `webtrip` crate
#    recompiles; its dependencies and std are reused from /opt/cargo-target.
#
#    `umask 000` makes every cache file (CARGO_TARGET_DIR, the cargo registry,
#    XDG_CACHE_HOME) world-writable as it is created, so any uid (CI as root,
#    agents as non-root) can reuse and extend the caches. We do this here (and in
#    steps 3, 5, and 6) instead of a trailing `chmod -R`: a `chmod` in its own layer
#    only flips metadata, but OverlayFS can't represent a metadata-only change,
#    so it copies every touched file into a new layer — that one `chmod` was the
#    single largest layer in the image (~2.8 GB of duplicated cache trees).
COPY Cargo.toml Cargo.lock package.json /opt/prewarm/
RUN set -eux; \
    umask 000; \
    mkdir -p "${XDG_CACHE_HOME}"; \
    cd /opt/prewarm; \
    mkdir -p src; \
    printf 'use wasm_bindgen::prelude::*;\n#[wasm_bindgen]\npub fn __prewarm() {}\n' > src/lib.rs; \
    npm run build:wasm; \
    npm run test; \
    # Warm the wasm *test*-profile dep graph (what `npm run test:wasm` builds).
    # build:wasm warms the wasm release profile and `npm run test` warms the native
    # host target; the wasm test build shares fingerprints with neither, so without
    # this every dep + std recompiles on first `test:wasm`. The flags must byte-match
    # the test:wasm npm script, so source them from package.json's `config` block
    # (the same single source the scripts read via $npm_package_config_*) rather than
    # re-hardcoding them. --no-run compiles without launching a browser.
    #
    # The `coverage`/`coverage:wasm` profiles are intentionally NOT warmed: the wasm
    # one can't be warmed from this test-less stub (its instrumented objects need
    # minicov's `__llvm_profile_runtime`, which only links when a real test harness
    # references it), so it recompiles once in CI — like native coverage always has.
    WASM_RF="$(node -p 'const c=require("./package.json").config; c.web_sys_cfg+" "+c.wasm_rustflags')"; \
    RUSTFLAGS="$WASM_RF" cargo test --no-run --target wasm32-unknown-unknown -Zbuild-std=std,panic_abort; \
    # Drop ONLY the stub's own crate artifacts, keeping cached deps + std. This
    # forces the local `webtrip` crate to rebuild from the real (mounted) source
    # at runtime — without it, cargo's mtime-based freshness check would treat
    # older-mtime mounted source as already-built and silently run stub code.
    # One clean per profile/target the warm-up produced webtrip artifacts in:
    # wasm release (build:wasm), wasm test (test --no-run), native (test).
    cargo clean -p webtrip --release --target wasm32-unknown-unknown; \
    cargo clean -p webtrip --target wasm32-unknown-unknown; \
    cargo clean -p webtrip; \
    cd /; \
    rm -rf /opt/prewarm

# 8. Login shells (`bash -lc ...`) re-source /etc/profile and would otherwise
#    drop the cargo bin dir from PATH, so add it there too. ENV PATH above
#    already covers non-login and exec-form invocations.
RUN printf 'export PATH=%s/bin:$PATH\n' "${CARGO_HOME}" > /etc/profile.d/rust.sh

WORKDIR /workspace
CMD ["bash"]
