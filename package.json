{
  "config": {
    "web_sys_cfg": "--cfg=web_sys_unstable_apis",
    "wasm_rustflags": "-Ctarget-feature=+atomics -Clink-args=--shared-memory -Clink-args=--max-memory=1073741824 -Clink-args=--import-memory -Clink-args=--export=__wasm_init_tls -Clink-args=--export=__tls_size -Clink-args=--export=__tls_align -Clink-args=--export=__tls_base -Clink-args=--export=__heap_base",
    "wasm_coverage_rustflags": "-Cinstrument-coverage -Zno-profiler-runtime -Clink-args=--no-gc-sections --cfg=wasm_bindgen_unstable_test_coverage",
    "wasm_coverage_cflags": "-matomics -mbulk-memory"
  },
  "scripts": {
    "build:wasm": "wasm-pack build --target web . -Zbuild-std=std,panic_abort --config \"target.wasm32-unknown-unknown.rustflags='$npm_package_config_web_sys_cfg $npm_package_config_wasm_rustflags'\"",
    "build:app": "tsc",
    "build": "npm run build:wasm && npm run build:app",
    "build:container": "docker build -t webtrip/webtrip-builder -f containers/build/Containerfile .",
    "check": "RUSTFLAGS=\"$npm_package_config_web_sys_cfg $npm_package_config_wasm_rustflags\" cargo check --target wasm32-unknown-unknown -Zbuild-std=std,panic_abort",
    "test": "RUSTFLAGS=\"$npm_package_config_web_sys_cfg\" cargo test",
    "coverage": "RUSTFLAGS=\"$npm_package_config_web_sys_cfg\" cargo llvm-cov --lcov --output-path lcov.info",
    "test:wasm": "RUSTFLAGS=\"$npm_package_config_web_sys_cfg $npm_package_config_wasm_rustflags\" scripts/wasm-browser-env.sh test wasm-pack test --headless --chrome -- -Zbuild-std=std,panic_abort",
    "coverage:wasm": "CFLAGS_wasm32_unknown_unknown=\"$npm_package_config_wasm_coverage_cflags\" CARGO_TARGET_WASM32_UNKNOWN_UNKNOWN_RUNNER=wasm-bindgen-test-runner CARGO_TARGET_WASM32_UNKNOWN_UNKNOWN_RUSTFLAGS=\"$npm_package_config_web_sys_cfg $npm_package_config_wasm_rustflags $npm_package_config_wasm_coverage_rustflags\" scripts/wasm-browser-env.sh coverage cargo llvm-cov test --target wasm32-unknown-unknown -Zbuild-std=std,panic_abort --lcov --output-path lcov.wasm.info",
    "clean": "rm -rf dist pkg target",
    "serve": "node server.js"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
